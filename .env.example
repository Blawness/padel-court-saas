# Copy to .env and fill in. Every value except DATABASE_URL is optional in development —
# see README ("What each missing credential does").

# --- Database (required) ---
# Postgres 16. Use the Supabase pooled connection string in production.
# NOTE: do NOT append `?schema=public` — that is a Prisma-ism and postgres.js fails on it.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/padel_booking"

# --- Supabase (blank -> signed dev-login cookie, no realtime) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Midtrans (blank -> mock Snap checkout at /payment/mock) ---
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# --- Email (blank -> confirmation emails logged to the console) ---
RESEND_API_KEY=
RESEND_FROM="Padel Booking <onboarding@resend.dev>"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Signs the dev-login cookie used when Supabase is not configured. Change it.
DEV_AUTH_SECRET="dev-only-change-me"

# Optional: protects the /api/cron/release-holds endpoint.
CRON_SECRET=
