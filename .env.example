# Copy to .env and fill in. Only DATABASE_URL and BETTER_AUTH_SECRET are required.

# --- Database (required) ---
# Postgres 16/17. In production use Neon's POOLED connection string (…-pooler…).
# Run migrations/seed against the DIRECT (non-pooled) endpoint instead.
# NOTE: do not append `?schema=public` — that's a Prisma-ism and postgres.js fails on it.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/padel_booking"

# --- Auth: Better Auth (required) ---
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL="http://localhost:3000"

# Optional: enables the "Masuk dengan Google" button when both are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Midtrans (optional; blank -> mock Snap checkout at /payment/mock) ---
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# The Snap popup runs in the browser, so it needs these two as NEXT_PUBLIC_ (they are
# inlined at build time). The client key is public by design; the server key never is.
# Set them to the same values as above, or Snap loads with an empty key and fails.
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# --- Vercel Blob (optional; blank -> venue form asks for an image URL instead) ---
# Auto-injected on Vercel once a Blob store is linked. For local uploads, copy it from
# the Vercel dashboard (Storage -> your Blob store -> .env.local tab).
BLOB_READ_WRITE_TOKEN=

# --- Email (optional; blank -> confirmation emails logged to the console) ---
RESEND_API_KEY=
RESEND_FROM="Padel Booking <onboarding@resend.dev>"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: protects the /api/cron/release-holds endpoint.
CRON_SECRET=
